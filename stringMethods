console.log(s8);

//converting string to uppercase and lowercase
let s9 = 'JavaScript';
let uCase = s9.toUpperCase();
let lCase = s9.toLowerCase();

console.log(uCase);
console.log(lCase);

//search
let s11 = 'def abc abc';
