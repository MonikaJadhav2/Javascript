console.log("Concatenated String: " + res);

//escape characters
const s3 = "\'GfG\' is a learning portal";
const s4 = "\"GfG\" is a learning portal";
const s5 = "\\GfG\\ is a learning portal";

console.log(s3);
console.log(s4);
console.log(s5);

//breaking long strings
const s6 = "'GeeksforGeeks' is \
a learning portal";

console.log(s6);

//finding substring
let s7 = 'JavaScript Tutorial';
