//string comparison
let s20 = "Ajay"
let s21 = new String("Ajay");

console.log(s20 == s21);  // true (type coercion)
console.log(s20 === s21); // false (strict comparison)
console.log(s20.localeCompare(s21)); // 0 (means they are equal lexicographically)

